// ADIPA Brand Colors
$color-purple = #704EFD
$color-purple-dark = #5232D4
$color-cyan = #2CB7FF
$color-brand-purple = #7D61F1
$color-brand-blue = #72CAF7
$color-pink = #FF017C
$color-deep-purple = #1F0A73
$color-footer-bg = #3A3F5A
$color-light-bg = #F3F4FF
$color-filter-bg = #F0F3FD
$color-border = #E5E5E5
$color-text-primary = #1D1D1D
$color-text-secondary = #5B6987
$color-error = #DD1F33
$color-success = #26990B
$color-modality-live = #26990B
$color-modality-online = #FFA927
$color-modality-presencial = #FF017C
$color-white = #FFFFFF

// Typography
$font-family = 'Poppins', sans-serif

// Shadows
$shadow-card = 0 4px 4.7px 0 rgba(0, 0, 0, 0.1)
$shadow-card-hover = 0 12px 22px rgba(0, 60, 91, 0.05)
$shadow-header = 0 4px 17px rgba(201, 201, 201, 0.25)

// Layout
$max-width = 1400px
$border-radius-card = 10px
$border-radius-button = 5px

// Breakpoints
$breakpoint-mobile = 375px
$breakpoint-tablet = 768px
$breakpoint-desktop = 1280px

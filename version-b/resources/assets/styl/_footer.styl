.footer
  background-color $color-footer-bg
  color $color-white

  &__container
    padding 40px 20px

    @media (min-width: $breakpoint-tablet)
      padding 50px 60px

  &__grid
    display grid
    grid-template-columns 1fr
    gap 32px

    @media (min-width: $breakpoint-tablet)
      grid-template-columns repeat(2, 1fr)

    @media (min-width: $breakpoint-desktop)
      grid-template-columns repeat(4, 1fr)

  &__logo
    font-size 24px
    font-weight 700
    display block
    margin-bottom 16px

  &__logo-adi
    color $color-brand-purple

  &__logo-pa
    color $color-brand-blue

  &__description
    font-size 14px
    color rgba(255, 255, 255, 0.7)
    line-height 1.6

  &__heading
    font-size 13px
    text-transform uppercase
    font-weight 400
    margin-bottom 16px

  &__links
    list-style none
    padding 0

    li
      margin-bottom 8px

  &__link
    font-size 13px
    text-transform uppercase
    font-weight 400
    color rgba(255, 255, 255, 0.8)
    text-decoration none
    display flex
    align-items center
    gap 8px
    transition color 0.2s

    &:hover
      color $color-white

  &__dot
    width 5px
    height 5px
    border-radius 50%
    background-color $color-purple
    display inline-block

  &__social
    display flex
    gap 12px

  &__social-link
    width 30px
    height 30px
    border-radius 50%
    background-color $color-white
    display flex
    align-items center
    justify-content center
    transition background-color 0.2s

    &:hover
      background-color rgba(255, 255, 255, 0.8)

    svg
      width 16px
      height 16px
      fill $color-footer-bg

  &__copyright
    border-top 1px solid rgba(255, 255, 255, 0.2)
    margin-top 32px
    padding-top 24px
    text-align center

    p
      font-size 12px
      color rgba(255, 255, 255, 0.6)

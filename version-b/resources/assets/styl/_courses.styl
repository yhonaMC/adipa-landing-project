// Category Filter
.category-filter
  display flex
  flex-wrap wrap
  gap 8px
  justify-content center
  margin-bottom 40px

  &__pill
    padding 8px 20px
    border-radius $border-radius-button
    font-size 14px
    font-weight 500
    font-family $font-family
    cursor pointer
    transition all 0.2s
    border none
    background-color $color-light-bg
    color $color-purple

    &:hover
      background-color rgba(112, 78, 253, 0.1)

    &--active
      background-color $color-purple
      color $color-white

// Courses Section
.courses
  padding 40px 0

  @media (min-width: $breakpoint-tablet)
    padding 80px 0

  &__title
    font-size 24px
    font-weight 600
    color $color-text-primary
    text-align center
    margin-bottom 32px

    @media (min-width: $breakpoint-tablet)
      font-size 30px

  &__grid
    display grid
    grid-template-columns 1fr
    gap 24px
    justify-items center

    @media (min-width: $breakpoint-tablet)
      grid-template-columns repeat(2, 1fr)

    @media (min-width: $breakpoint-desktop)
      grid-template-columns repeat(3, 1fr)

  &__empty
    text-align center
    color $color-text-secondary
    margin-top 32px

// Course Card
.course-card
  background-color $color-white
  border-radius $border-radius-card
  border 1px solid $color-border
  box-shadow $shadow-card
  max-width 350px
  width 100%
  display flex
  flex-direction column
  transition all 0.5s

  &:hover
    box-shadow $shadow-card-hover
    transform translateY(-10px)

  &__image-wrapper
    position relative
    aspect-ratio 16 / 9
    overflow hidden
    border-radius $border-radius-card $border-radius-card 0 0

  &__image
    width 100%
    height 100%
    object-fit cover

  &__modality
    position absolute
    bottom 20px
    right 0
    background-color $color-white
    border-radius 5px 0 0 5px
    padding 2px 10px
    box-shadow 0 4px 4px 0 rgba(0, 0, 0, 0.39)
    display flex
    align-items center
    gap 6px

  &__modality-dot
    width 8px
    height 8px
    border-radius 50%

    &--en-vivo
      background-color $color-modality-live

    &--online
      background-color $color-modality-online

    &--presencial
      background-color $color-modality-presencial

  &__modality-text
    font-size 12px
    font-weight 500
    color $color-text-primary

  &__rating
    position absolute
    bottom 20px
    left 0
    background-color rgba(0, 0, 0, 0.6)
    color $color-white
    border-radius 0 5px 5px 0
    padding 2px 8px
    display flex
    align-items center
    gap 4px

  &__star
    width 12px
    height 12px
    fill #ffd705

  &__rating-value
    font-size 12px
    font-weight 600

  &__rating-count
    font-size 12px
    opacity 0.7

  &__body
    padding 25px 20px 20px
    display flex
    flex-direction column
    justify-content space-between
    flex 1
    min-height 260px

  &__type-tag
    display inline-block
    background-color $color-deep-purple
    color $color-white
    font-size 10px
    font-weight 700
    text-transform uppercase
    padding 2px 6px
    border-radius 5px
    margin-bottom 8px

  &__title
    font-size 13px
    line-height 17px
    font-weight 600
    color $color-text-primary
    min-height 52px
    margin-bottom 10px

  &__instructor
    font-size 12px
    color $color-text-secondary
    margin-bottom 4px

  &__date
    font-size 12px
    color $color-text-secondary
    margin-bottom 16px

  &__prices
    display flex
    align-items center
    gap 8px
    margin-bottom 16px
    flex-wrap wrap

  &__price-current
    font-size 19px
    line-height 22px
    font-weight 700
    color $color-text-primary

  &__price-original
    font-size 16px
    line-height 22px
    color rgba(0, 0, 0, 0.7)
    text-decoration line-through

  &__discount
    background-color $color-cyan
    color $color-white
    font-size 14px
    font-weight 700
    padding 2px 10px
    border-radius 5px

  &__cta
    width 100%
    background-color $color-purple
    color $color-white
    font-size 17px
    font-weight 500
    font-family $font-family
    padding 10px 32px
    border-radius $border-radius-button
    border 1px solid $color-purple
    cursor pointer
    transition all 0.2s

    &:hover
      background-color $color-purple-dark

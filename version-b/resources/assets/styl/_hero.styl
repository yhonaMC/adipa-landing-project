.hero
  background-color $color-purple
  padding-top 110px
  padding-bottom 64px

  @media (min-width: $breakpoint-desktop)
    padding-top 170px
    padding-bottom 80px

  &__container
    text-align center

  &__title
    color $color-white
    font-size 24px
    line-height 1.3
    font-weight 600
    margin-bottom 16px

    @media (min-width: $breakpoint-tablet)
      font-size 36px
      line-height 48px

    strong
      font-weight 700
      text-transform uppercase

  &__description
    color rgba(255, 255, 255, 0.8)
    font-size 16px
    max-width 640px
    margin 0 auto 32px

    @media (min-width: $breakpoint-tablet)
      font-size 18px

  &__cta
    display inline-block
    background-color $color-cyan
    color $color-white
    font-size 17px
    font-weight 500
    padding 12px 32px
    border-radius $border-radius-button
    border 1px solid $color-cyan
    text-decoration none
    transition all 0.2s
    filter drop-shadow(0 4px 10px rgba(44, 183, 255, 0.3))

    &:hover
      filter brightness(1.1)

  &__pills
    display flex
    flex-wrap wrap
    justify-content center
    gap 8px
    margin-top 32px

  &__pill
    padding 4px 12px
    border-radius 7px
    color $color-white
    font-size 14px
    background-color rgba(255, 255, 255, 0.3)
    border 1px solid $color-white
    cursor pointer
    transition background-color 0.2s

    &:hover
      background-color rgba(255, 255, 255, 0.5)

// Hero wrapper — push below fixed header
.hero-wrapper
  padding-top 70px

  @media (min-width: $breakpoint-tablet)
    padding-top 130px

// Search section — solid purple background
.hero-search
  background-color #704EFD
  padding 36px 20px

  @media (min-width: $breakpoint-tablet)
    padding 48px 40px

  &__container
    max-width $max-width
    text-align center

  &__heading
    font-size 28px
    line-height 1.25
    color $color-white
    font-weight 700
    font-style italic
    margin-bottom 12px

    @media (min-width: $breakpoint-tablet)
      font-size 36px

  &__subheading
    font-size 15px
    line-height 1.5
    color rgba(255, 255, 255, 0.9)
    margin-bottom 24px

    @media (min-width: $breakpoint-tablet)
      font-size 17px

  &__input-wrapper
    position relative
    width 60%
    margin 0 auto 20px

    @media (max-width: 600px)
      width 90%

  &__input
    width 100%
    background-color $color-white
    font-size 14px
    color $color-text-primary
    border none
    border-radius $border-radius-button
    padding 12px 48px 12px 16px
    outline none
    font-family $font-family

    &::placeholder
      color $color-text-secondary

  &__icon
    position absolute
    right 16px
    top 50%
    transform translateY(-50%)
    pointer-events none
    color $color-text-secondary

  &__chips-row
    display flex
    align-items center
    justify-content center
    flex-wrap wrap
    gap 10px

  &__chips-label
    color $color-white
    font-size 14px
    font-weight 600
    white-space nowrap

  &__chips
    display flex
    flex-wrap wrap
    gap 8px
    justify-content center

  &__chip
    background-color rgba(255, 255, 255, 0.2)
    padding 5px 12px
    font-size 12px
    color $color-white
    font-weight 600
    border 1px solid rgba(255, 255, 255, 0.7)
    border-radius $border-radius-button
    cursor pointer
    font-family $font-family
    transition transform 0.15s, background-color 0.15s

    &:hover
      background-color rgba(255, 255, 255, 0.35)
      transform translateY(-2px)

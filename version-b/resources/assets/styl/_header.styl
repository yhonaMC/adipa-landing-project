.header
  position fixed
  top 0
  left 0
  width 100%
  background-color $color-white
  box-shadow $shadow-header
  z-index 20

  // Primary bar
  &__primary
    height 70px
    border-bottom 1px solid rgba(229, 229, 229, 0.4)

  &__primary-inner
    display flex
    align-items center
    justify-content space-between
    height 100%
    gap 16px

  &__logo
    text-decoration none
    flex-shrink 0
    display flex
    align-items center

  &__logo-text
    font-size 38px
    font-weight 700
    line-height 1
    letter-spacing -0.5px
    user-select none

  &__logo-letter
    &--purple
      color $color-brand-purple

    &--blue
      color $color-brand-blue

  // Search bar (desktop only)
  &__search
    display none

    @media (min-width: $breakpoint-tablet)
      display flex
      flex 1
      max-width 520px
      margin 0 16px

  &__search-wrapper
    display flex
    width 100%
    border-radius $border-radius-button
    border 2px solid #2CB7FF
    overflow hidden
    background-color $color-white

  &__search-input
    flex 1
    padding 10px 16px
    font-size 14px
    color $color-text-primary
    background transparent
    border none
    outline none
    font-family $font-family

    &::placeholder
      color rgba(91, 105, 135, 0.7)

  &__search-btn
    flex-shrink 0
    background-color #2CB7FF
    color $color-white
    border none
    padding 0 16px
    display flex
    align-items center
    justify-content center
    cursor pointer
    transition background-color 0.2s

    &:hover
      background-color darken(#2CB7FF, 10%)

  // Right actions (desktop)
  &__actions
    display none

    @media (min-width: $breakpoint-tablet)
      display flex
      align-items center
      gap 12px
      flex-shrink 0

  &__action-link
    color $color-text-primary
    font-size 14px
    font-weight 500
    text-decoration none
    white-space nowrap
    transition color 0.2s

    &:hover
      color $color-purple

  &__btn
    font-family $font-family
    font-size 14px
    font-weight 500
    padding 8px 20px
    border-radius $border-radius-button
    cursor pointer
    transition all 0.2s
    text-decoration none
    text-align center
    display inline-block
    white-space nowrap

    &--outline
      background-color transparent
      color $color-purple
      border 1px solid $color-purple

      &:hover
        background-color $color-light-bg

    &--primary
      background-color $color-purple
      color $color-white
      border 1px solid $color-purple

      &:hover
        background-color $color-purple-dark

  &__cart-btn
    background none
    border none
    color #704EFD
    cursor pointer
    transition color 0.2s
    display flex
    align-items center

    &:hover
      color $color-purple-dark

  // Hamburger (mobile only)
  &__hamburger
    display flex
    flex-direction column
    justify-content center
    align-items center
    width 36px
    height 36px
    gap 5px
    background none
    border none
    cursor pointer
    flex-shrink 0

    @media (min-width: $breakpoint-tablet)
      display none

  &__hamburger-line
    display block
    width 24px
    height 2px
    background-color $color-text-primary
    transition all 0.3s
    transform-origin center

  // Secondary bar (desktop only)
  &__secondary
    display none

    @media (min-width: $breakpoint-tablet)
      display flex
      height 60px
      align-items center

  &__secondary-inner
    display flex
    align-items center
    gap 0
    width 100%
    overflow-x auto

  &__nav-link
    flex-shrink 0
    display flex
    align-items center
    gap 2px
    padding 8px 12px
    font-size 14px
    white-space nowrap
    transition color 0.2s
    text-decoration none
    font-weight 400
    color $color-text-primary

    &:hover
      color $color-purple

    &--current
      font-weight 700
      color $color-purple
      border-bottom 2px solid $color-purple

  // Mobile menu
  &__mobile-menu
    background-color $color-white
    border-top 1px solid $color-border
    overflow hidden
    transition max-height 0.3s, opacity 0.3s

    @media (min-width: $breakpoint-tablet)
      display none !important

  &__mobile-nav
    padding 16px 20px

  &__mobile-link
    display flex
    align-items center
    justify-content space-between
    padding 12px 0
    font-size 14px
    font-weight 500
    color $color-text-primary
    text-decoration none
    border-bottom 1px solid rgba(229, 229, 229, 0.5)
    transition color 0.2s

    &:last-of-type
      border-bottom none

    &:hover
      color $color-purple

    &--current
      font-weight 700
      color $color-purple

  &__mobile-actions
    display flex
    flex-direction column
    gap 8px
    margin-top 16px
    padding-top 16px
    border-top 1px solid $color-border

